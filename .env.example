APP_NAME="SwaedUAE"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
# Local: http://localhost — production MUST match the public site:
#   APP_URL=https://swaeduae.ae
APP_URL=http://localhost
# Vite: run `npm run build` (or `composer build-frontend`) before deploy; ship `public/build` with the app, then `php artisan optimize:clear` on the server.

# Optional canonical host label (footer, docs); not required for Laravel routing
APP_DOMAIN=swaeduae.ae

# Optional social preview image: full HTTPS URL or site path (e.g. /images/og.jpg). Used on home and as CMS fallback.
# DEFAULT_OG_IMAGE_URL=https://swaeduae.ae/images/og-default.jpg

# Email verification: users must verify before dashboard and volunteer opportunity actions. Use real SMTP in production (see MAIL_* above).

# Cloudflare: set true in production behind the orange-cloud proxy so Laravel
# trusts X-Forwarded-* (real client IP, HTTPS). Required for swaeduae.ae in prod.
TRUSTED_PROXIES=false

# Optional Phase H2 hardening: send Content-Security-Policy-Report-Only on every response (directive string).
# Leave unset or empty to omit. Prefer Report-Only until violations are understood.
# CSP_REPORT_ONLY="default-src 'self'"

# Enterprise (roadmap H1 / I5): require TOTP 2FA for admin + super-admin after password sign-in.
# Tests force false via phpunit.xml. Enable in production when staff are ready.
ADMIN_TWO_FACTOR_REQUIRED=false

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# PostgreSQL only (production, staging, local). Create role + DB, then migrate.
# Local: `docker compose -f docker-compose.postgres.yml up -d` then use DB_PASSWORD below.
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=swaeduae
DB_USERNAME=swaeduae
DB_PASSWORD=swaeduae

# Production: set a strong secret; use sslmode=require in DB_URL when the host requires TLS.
# DB_URL=pgsql://swaeduae:secret@127.0.0.1:5432/swaeduae?sslmode=require

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Local: log. Production: smtp via Zoho Mail (see Zoho docs for host/port/TLS).
#
# Mailbox roles (create all four in Zoho; never commit real passwords to git — set MAIL_PASSWORD only in .env on the server):
#   info@     — public Contact form + general / partnership / media inquiries
#   support@ — Help & support form + global Reply-To on automated mail
#   admin@   — internal alerts (new org registration, attendance disputes, etc.)
#   noreply@ — SMTP user + default From for verification, password reset, application mail, etc.
MAIL_INFO_ADDRESS=info@swaeduae.ae
MAIL_ADMIN_ADDRESS=admin@swaeduae.ae
MAIL_SUPPORT_ADDRESS=support@swaeduae.ae
# Optional: Contact form topic “Data protection & account data”. Defaults to MAIL_SUPPORT_ADDRESS when unset.
# MAIL_PRIVACY_ADDRESS=privacy@swaeduae.ae
# Youth Councils public page — dedicated inbox (see /youth-councils).
MAIL_YOUTH_COUNCILS_ADDRESS=youthcouncils@swaeduae.ae
MAIL_NOREPLY_ADDRESS=noreply@swaeduae.ae
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=smtp.zoho.com
MAIL_PORT=587
# Use the noreply@ mailbox credentials when your provider allows it as the SMTP login.
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=tls
# Default From for automated app mail (legal issuer name recommended).
MAIL_FROM_ADDRESS="${MAIL_NOREPLY_ADDRESS}"
MAIL_FROM_NAME="SwaedUAE Association for Culture and Community Empowerment"
# Replies on system mail go to support unless a Mailable sets its own Reply-To (e.g. contact form uses the submitter).
MAIL_REPLY_TO_ADDRESS="${MAIL_SUPPORT_ADDRESS}"
MAIL_REPLY_TO_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# OwenIt Auditing (see config/audit.php)
AUDITING_ENABLED=true
# Set true so Artisan/Tinker resolves the acting user when writing audit rows
AUDITING_CONSOLE=false
